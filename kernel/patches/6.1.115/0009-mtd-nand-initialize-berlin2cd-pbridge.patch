+static void marvell_berlin2cd_init_pbridge(struct marvell_nfc *nfc)
+{
+	void __iomem *regs = nfc->pbridge_regs;
+	u32 status;
+	unsigned int i;
+	int ret;
+
+	if (!nfc->caps->has_pbridge)
+		return;
+
+	status = readl_relaxed(regs + BERLIN2CD_PB_DHUB_BUSY) |
+		 readl_relaxed(regs + BERLIN2CD_PB_DHUB_PENDING) |
+		 readl_relaxed(regs + BERLIN2CD_PB_HBO_BUSY);
+	if (status) {
+		dev_warn(nfc->dev,
+			 "pBridge initialization skipped: engine is active (%08x)\n",
+			 status);
+		return;
+	}
+
+	for (i = 0; i < BERLIN2CD_PB_CHANNELS; i++)
+		writel_relaxed(0, regs + BERLIN2CD_PB_DHUB_CHANNEL_CFG +
+			       i * BERLIN2CD_PB_CHANNEL_STRIDE +
+			       BERLIN2CD_PB_CHANNEL_START);
+
+	for (i = 0; i < BERLIN2CD_PB_QUEUES; i++) {
+		void __iomem *fifo = regs + BERLIN2CD_PB_HBO_FIFO_CFG +
+				     i * BERLIN2CD_PB_FIFO_STRIDE;
+
+		writel_relaxed(0, fifo + BERLIN2CD_PB_FIFO_START);
+		writel_relaxed(1, fifo + BERLIN2CD_PB_FIFO_CLEAR);
+	}
+
+	ret = readl_relaxed_poll_timeout(regs + BERLIN2CD_PB_HBO_BUSY,
+					 status, !(status & GENMASK(7, 0)), 1,
+					 BERLIN2CD_PB_INIT_TIMEOUT_US);
+	if (ret) {
+		dev_err(nfc->dev,
+			"pBridge FIFO clear timed out: HBO-busy=%08x\n",
+			status);
+		return;
+	}
+
+	writel_relaxed(0xf0000000, regs + BERLIN2CD_PB_BCM_BASE);
+
+	for (i = 0; i < BERLIN2CD_PB_CHANNELS; i++)
+		writel_relaxed(BERLIN2CD_PB_CHANNEL_MTU_32,
+			       regs + BERLIN2CD_PB_DHUB_CHANNEL_CFG +
+			       i * BERLIN2CD_PB_CHANNEL_STRIDE);
+
+	for (i = 0; i < ARRAY_SIZE(marvell_berlin2cd_pbridge_queues); i++) {
+		void __iomem *fifo = regs + BERLIN2CD_PB_HBO_FIFO_CFG +
+				     i * BERLIN2CD_PB_FIFO_STRIDE;
+
+		writel_relaxed(marvell_berlin2cd_pbridge_queues[i].base, fifo);
+		writel_relaxed(marvell_berlin2cd_pbridge_queues[i].depth,
+			       regs + BERLIN2CD_PB_HBO_SEMA_CFG +
+			       i * BERLIN2CD_PB_SEMA_STRIDE);
+		writel_relaxed(1, fifo + BERLIN2CD_PB_FIFO_START);
+	}
+
+	for (i = 0; i < ARRAY_SIZE(marvell_berlin2cd_pbridge_semas); i++)
+		writel_relaxed(1, regs + BERLIN2CD_PB_DHUB_SEMA_CFG +
+			       marvell_berlin2cd_pbridge_semas[i].id *
+			       BERLIN2CD_PB_SEMA_STRIDE);
+
+	for (i = 0; i < BERLIN2CD_PB_CHANNELS; i++)
+		writel_relaxed(1, regs + BERLIN2CD_PB_DHUB_CHANNEL_CFG +
+			       i * BERLIN2CD_PB_CHANNEL_STRIDE +
+			       BERLIN2CD_PB_CHANNEL_START);
+
+	/* Make every configuration write visible before querying the engine. */
+	wmb();
+	dev_info(nfc->dev,
+		 "pBridge initialized: four 32-byte-MTU channels, eight Valve-layout FIFOs, nine depth-one semaphores\n");
+	marvell_berlin2cd_dump_pbridge(nfc, "initialized");
 }
 
