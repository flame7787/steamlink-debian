+static bool
+marvell_berlin2cd_ident_op_supported(const struct nand_operation *op)
+{
+	const struct nand_op_instr *instrs = op->instrs;
+
+	if (!op->ninstrs || instrs[0].type != NAND_OP_CMD_INSTR)
+		return false;
+
+	switch (instrs[0].ctx.cmd.opcode) {
+	case NAND_CMD_RESET:
+		return op->ninstrs == 2 &&
+		       instrs[1].type == NAND_OP_WAITRDY_INSTR;
+	case NAND_CMD_READID:
+		return op->ninstrs == 3 &&
+		       instrs[1].type == NAND_OP_ADDR_INSTR &&
+		       instrs[1].ctx.addr.naddrs == 1 &&
+		       instrs[2].type == NAND_OP_DATA_IN_INSTR &&
+		       instrs[2].ctx.data.len <= 8 &&
+		       instrs[2].ctx.data.force_8bit;
+	case NAND_CMD_STATUS:
+		return op->ninstrs == 2 &&
+		       instrs[1].type == NAND_OP_DATA_IN_INSTR &&
+		       instrs[1].ctx.data.len == 1;
+	case NAND_CMD_PARAM:
+		return op->ninstrs == 4 &&
+		       instrs[1].type == NAND_OP_ADDR_INSTR &&
+		       instrs[1].ctx.addr.naddrs == 1 &&
+		       instrs[1].ctx.addr.addrs[0] == 0 &&
+		       instrs[2].type == NAND_OP_WAITRDY_INSTR &&
+		       instrs[3].type == NAND_OP_DATA_IN_INSTR &&
+		       instrs[3].ctx.data.len ==
+					     sizeof(struct nand_onfi_params) &&
+		       instrs[3].ctx.data.force_8bit;
+	default:
+		return false;
+	}
+}
+
 static int marvell_nfc_exec_op(struct nand_chip *chip,
 			       const struct nand_operation *op,
 			       bool check_only)
@@ -2322,15 +2381,19 @@ static int marvell_nfc_exec_op(struct nand_chip *chip,
 	if (!check_only)
 		marvell_nfc_select_target(chip, op->cs);
 
-	if (nfc->caps->probe_only)
+	if (nfc->caps->probe_only) {
+		if (!marvell_berlin2cd_ident_op_supported(op))
+			return -EOPNOTSUPP;
+
 		return nand_op_parser_exec_op(chip, &marvell_berlin2cd_op_parser,
 					      op, check_only);
-	else if (nfc->caps->is_nfcv2 && !nfc->caps->use_nfcv1_parser)
+	} else if (nfc->caps->is_nfcv2 && !nfc->caps->use_nfcv1_parser) {
 		return nand_op_parser_exec_op(chip, &marvell_nfcv2_op_parser,
 					      op, check_only);
-	else
+	} else {
 		return nand_op_parser_exec_op(chip, &marvell_nfcv1_op_parser,
 					      op, check_only);
+	}
