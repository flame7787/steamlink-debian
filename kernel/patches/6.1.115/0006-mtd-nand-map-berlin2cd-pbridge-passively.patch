+static void marvell_berlin2cd_dump_pbridge(struct marvell_nfc *nfc)
+{
+	void __iomem *regs = nfc->pbridge_regs;
+
+	if (!nfc->caps->has_pbridge)
+		return;
+
+	dev_info(nfc->dev,
+		 "passive pBridge status: clock=%lu Hz sem-empty=%08x sem-full=%08x dHub-busy=%08x dHub-pending=%08x\n",
+		 clk_get_rate(nfc->pbridge_clk),
+		 readl_relaxed(regs + BERLIN2CD_PB_SEMA_EMPTY),
+		 readl_relaxed(regs + BERLIN2CD_PB_SEMA_FULL),
+		 readl_relaxed(regs + BERLIN2CD_PB_DHUB_BUSY),
+		 readl_relaxed(regs + BERLIN2CD_PB_DHUB_PENDING));
+	dev_info(nfc->dev,
+		 "passive pBridge control: bus-reset-enable=%08x bus-reset-done=%08x BCM-error=%08x BCM-base=%08x\n",
+		 readl_relaxed(regs + BERLIN2CD_PB_BUS_RESET_ENABLE),
+		 readl_relaxed(regs + BERLIN2CD_PB_BUS_RESET_DONE),
+		 readl_relaxed(regs + BERLIN2CD_PB_BCM_ERROR),
+		 readl_relaxed(regs + BERLIN2CD_PB_BCM_BASE));
+}
