 	}
+	state_before = readl_relaxed(channel_state);
 
 	if (!berlin2cd_clear_full_event(regs,
 					BERLIN2CD_PB_HBO_SEMA_FULL,
@@ -856,7 +864,9 @@ static void marvell_berlin2cd_test_pbridge(struct marvell_nfc *nfc)
 	first_producer = marvell_berlin2cd_pbridge_sema_query(regs,
 							      BERLIN2CD_PB_HBO_SEMA_QUERY,
 							      BERLIN2CD_PB_TEST_QUEUE, false);
+	first_state = readl_relaxed(channel_state);
 	ret = berlin2cd_wait_test_queue(nfc, 1, &producer, &consumer);
