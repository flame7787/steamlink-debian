+	void __iomem *channel_state = regs +
+		BERLIN2CD_PB_DHUB_CHANNEL_STATE +
+		BERLIN2CD_PB_TEST_CHANNEL * sizeof(u32);
 	void __iomem *tcm = regs + BERLIN2CD_PB_TEST_TCM_OFFSET;
 	u32 command = BERLIN2CD_PB_TEST_QUEUE |
 		      (1 << BERLIN2CD_PB_SEMA_DELTA_SHIFT);
 	u32 saved_low, saved_high, actual_low, actual_high;
 	u32 producer = 0, consumer = 0, status;
 	u32 first_producer = 0, first_consumer = 0;
+	u32 state_before, first_state, final_state;
 	u32 empty_event = 0, full_event = 0;
 	bool passed = false, pushed = false;
 	int cleanup_ret = 0;
@@ -811,8 +815,11 @@ static void marvell_berlin2cd_test_pbridge(struct marvell_nfc *nfc)
 
 	writel_relaxed(BERLIN2CD_PB_TEST_TCM_OFFSET, fifo);
 	writel_relaxed(BERLIN2CD_PB_TEST_QUEUE_DEPTH, sema);
-	writel_relaxed(1, fifo + BERLIN2CD_PB_FIFO_START);
-	/* Publish queue configuration before querying it. */
+	/*
