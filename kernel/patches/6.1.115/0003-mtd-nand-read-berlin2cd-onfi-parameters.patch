READID now reliably identifies the Steam Link NAND as Micron
2c 68 04 4a a9 and returns the ONFI signature at address 0x20. The
identification still fails because the explicit NFCv1 parser does not
accept the ONFI parameter-page operation.

Add a Berlin2CD-only parser with the existing identification commands and
a single monolithic 256-byte parameter-page read. The controller uses its
NFCv2 length-override support while transferring data through PIO. Log the
command, initial parameter bytes, ONFI CRC and final register state. This
remains probe-only and does not expose page I/O or an MTD device.

---
 drivers/mtd/nand/raw/marvell_nand.c | 101 ++++++++++++++++++++++++++++-
 1 file changed, 99 insertions(+), 2 deletions(-)

diff --git a/drivers/mtd/nand/raw/marvell_nand.c b/drivers/mtd/nand/raw/marvell_nand.c
index 27d1c81..568e7e7 100644
--- a/drivers/mtd/nand/raw/marvell_nand.c
+++ b/drivers/mtd/nand/raw/marvell_nand.c
@@ -441,6 +441,19 @@ static void marvell_nfc_dump_probe_regs(struct marvell_nfc *nfc,
 		 readl_relaxed(nfc->regs + NDTR1));
 }
 
+static u16 marvell_nfc_onfi_crc16(u16 crc, const u8 *buf, size_t len)
+{
+	int i;
+
+	while (len--) {
+		crc ^= *buf++ << 8;
+		for (i = 0; i < 8; i++)
+			crc = (crc << 1) ^ ((crc & 0x8000) ? 0x8005 : 0);
+	}
+
+	return crc;
+}
+
 static inline struct marvell_nfc *to_marvell_nfc(struct nand_controller *ctrl)
 {
 	return container_of(ctrl, struct marvell_nfc, controller);
@@ -513,6 +526,32 @@ struct marvell_nfc_op {
 	const struct nand_op_instr *data_instr;
 };
 
+static void marvell_nfc_dump_onfi_params(struct marvell_nfc *nfc,
+					 const struct nand_subop *subop,
+					 struct marvell_nfc_op *nfc_op)
+{
+	const struct nand_op_instr *instr = nfc_op->data_instr;
+	unsigned int op_id = nfc_op->data_instr_idx;
+	unsigned int len = nand_subop_get_data_len(subop, op_id);
+	unsigned int offset = nand_subop_get_data_start_off(subop, op_id);
+	const u8 *buf = instr->ctx.data.buf.in + offset;
+
+	dev_info(nfc->dev, "ONFI parameter data (%u bytes, first %u): %*ph\n",
+		 len, min_t(unsigned int, len, 32),
+		 (int)min_t(unsigned int, len, 32), buf);
+
+	if (len >= sizeof(struct nand_onfi_params)) {
+		const struct nand_onfi_params *params = (const void *)buf;
+		u16 expected = le16_to_cpu(params->crc);
+		u16 calculated = marvell_nfc_onfi_crc16(ONFI_CRC_BASE, buf, 254);
+
+		dev_info(nfc->dev,
+			 "ONFI parameter CRC: calculated=%04x expected=%04x (%s)\n",
+			 calculated, expected,
+			 calculated == expected ? "valid" : "invalid");
+	}
+}
+
 /*
  * Internal helper to conditionnally apply a delay (from the above structure,
  * most of the time).
@@ -1851,11 +1890,22 @@ static int marvell_nfc_monolithic_access_exec(struct nand_chip *chip,
 					      const struct nand_subop *subop)
 {
 	struct marvell_nfc_op nfc_op;
+	struct marvell_nfc *nfc = to_marvell_nfc(chip->controller);
+	bool onfi_params;
 	bool reading;
 	int ret;
 
 	marvell_nfc_parse_instructions(chip, subop, &nfc_op);
+	onfi_params = nfc->caps->probe_only &&
+		      subop->instrs[0].type == NAND_OP_CMD_INSTR &&
+		      subop->instrs[0].ctx.cmd.opcode == NAND_CMD_PARAM;
 	reading = (nfc_op.data_instr->type == NAND_OP_DATA_IN_INSTR);
+	if (onfi_params)
+		dev_info(nfc->dev,
+			 "ONFI parameter command: NDCR=%08x NDSR=%08x NDCB=%08x %08x %08x %08x\n",
+			 readl_relaxed(nfc->regs + NDCR),
+			 readl_relaxed(nfc->regs + NDSR), nfc_op.ndcb[0],
+			 nfc_op.ndcb[1], nfc_op.ndcb[2], nfc_op.ndcb[3]);
 
 	ret = marvell_nfc_prepare_cmd(chip);
 	if (ret)
@@ -1880,9 +1930,19 @@ static int marvell_nfc_monolithic_access_exec(struct nand_chip *chip,
 	}
 
 	marvell_nfc_xfer_data_pio(chip, subop, &nfc_op);
+	if (onfi_params)
+		marvell_nfc_dump_onfi_params(nfc, subop, &nfc_op);
+
 	ret = marvell_nfc_wait_cmdd(chip);
-	if (ret)
+	if (ret) {
+		if (onfi_params)
+			marvell_nfc_dump_probe_regs(nfc,
+						    "ONFI parameter read failed");
 		return ret;
+	}
+
+	if (onfi_params)
+		marvell_nfc_dump_probe_regs(nfc, "ONFI parameter read complete");
 
 	cond_delay(nfc_op.data_delay_ns);
 
@@ -2219,6 +2279,40 @@ static const struct nand_op_parser marvell_nfcv1_op_parser = NAND_OP_PARSER(
 		NAND_OP_PARSER_PAT_WAITRDY_ELEM(false)),
 	);
 
+static const struct nand_op_parser marvell_berlin2cd_op_parser = NAND_OP_PARSER(
+	/* Identification-only ONFI parameter-page read. */
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_monolithic_access_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_ADDR_ELEM(false, MAX_ADDRESS_CYC_NFCV1),
+		NAND_OP_PARSER_PAT_WAITRDY_ELEM(false),
+		NAND_OP_PARSER_PAT_DATA_IN_ELEM(false,
+					     sizeof(struct nand_onfi_params))),
+	/* Retain the explicit NFCv1 identification command patterns. */
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_read_id_type_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_ADDR_ELEM(false, MAX_ADDRESS_CYC_NFCV1),
+		NAND_OP_PARSER_PAT_DATA_IN_ELEM(false, 8)),
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_erase_cmd_type_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_ADDR_ELEM(false, MAX_ADDRESS_CYC_NFCV1),
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_WAITRDY_ELEM(false)),
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_read_status_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_DATA_IN_ELEM(false, 1)),
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_reset_cmd_type_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_WAITRDY_ELEM(false)),
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_naked_waitrdy_exec,
+		NAND_OP_PARSER_PAT_WAITRDY_ELEM(false)),
+	);
+
 static int marvell_nfc_exec_op(struct nand_chip *chip,
 			       const struct nand_operation *op,
 			       bool check_only)
@@ -2228,7 +2322,10 @@ static int marvell_nfc_exec_op(struct nand_chip *chip,
 	if (!check_only)
 		marvell_nfc_select_target(chip, op->cs);
 
-	if (nfc->caps->is_nfcv2 && !nfc->caps->use_nfcv1_parser)
+	if (nfc->caps->probe_only)
+		return nand_op_parser_exec_op(chip, &marvell_berlin2cd_op_parser,
+					      op, check_only);
+	else if (nfc->caps->is_nfcv2 && !nfc->caps->use_nfcv1_parser)
 		return nand_op_parser_exec_op(chip, &marvell_nfcv2_op_parser,
 					      op, check_only);
 	else
