 		dev_info(nfc->dev,
-			 "ONFI parameter command: NDCR=%08x NDSR=%08x NDCB=%08x %08x %08x %08x\n",
+			 "%s command: NDCR=%08x NDSR=%08x NDCB=%08x %08x %08x %08x\n",
+			 onfi_label,
 			 readl_relaxed(nfc->regs + NDCR),
 			 readl_relaxed(nfc->regs + NDSR), nfc_op.ndcb[0],
 			 nfc_op.ndcb[1], nfc_op.ndcb[2], nfc_op.ndcb[3]);
@@ -1955,24 +2044,33 @@ static int marvell_nfc_monolithic_access_exec(struct nand_chip *chip,
 
 	ret = marvell_nfc_xfer_data_pio(chip, subop, &nfc_op);
 	if (ret) {
-		if (onfi_params)
+		if (onfi_label)
 			marvell_nfc_dump_probe_regs(nfc,
-						    "ONFI parameter PIO failed");
+					onfi_ext_params ?
+					"ONFI extended parameter PIO failed" :
+					"ONFI parameter PIO failed");
 		return ret;
 	}
 	if (onfi_params)
 		marvell_nfc_dump_onfi_params(nfc, subop, &nfc_op);
+	else if (onfi_ext_params)
+		marvell_nfc_dump_onfi_ext_params(nfc, subop, &nfc_op);
 
 	ret = marvell_nfc_wait_cmdd(chip);
 	if (ret) {
-		if (onfi_params)
+		if (onfi_label)
 			marvell_nfc_dump_probe_regs(nfc,
-						    "ONFI parameter read failed");
+					onfi_ext_params ?
+					"ONFI extended parameter read failed" :
+					"ONFI parameter read failed");
 		return ret;
 	}
 
-	if (onfi_params)
-		marvell_nfc_dump_probe_regs(nfc, "ONFI parameter read complete");
+	if (onfi_label)
+		marvell_nfc_dump_probe_regs(nfc,
+			onfi_ext_params ?
+			"ONFI extended parameter read complete" :
+			"ONFI parameter read complete");
 
 	cond_delay(nfc_op.data_delay_ns);
 
@@ -2310,6 +2408,14 @@ static const struct nand_op_parser marvell_nfcv1_op_parser = NAND_OP_PARSER(
 	);
 
 static const struct nand_op_parser marvell_berlin2cd_op_parser = NAND_OP_PARSER(
+	/* Read the ECC section from the extended ONFI parameter page. */
+	NAND_OP_PARSER_PATTERN(
+		marvell_nfc_monolithic_access_exec,
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_ADDR_ELEM(false, 2),
+		NAND_OP_PARSER_PAT_CMD_ELEM(false),
+		NAND_OP_PARSER_PAT_DATA_IN_ELEM(false,
+					     BERLIN2CD_ONFI_EXT_PARAM_LEN)),
 	/* Identification-only ONFI parameter-page read. */
 	NAND_OP_PARSER_PATTERN(
 		marvell_nfc_monolithic_access_exec,
@@ -2367,6 +2473,20 @@ marvell_berlin2cd_ident_op_supported(const struct nand_operation *op)
 		       instrs[3].ctx.data.len ==
 					     sizeof(struct nand_onfi_params) &&
 		       instrs[3].ctx.data.force_8bit;
+	case NAND_CMD_RNDOUT:
+		return op->ninstrs == 4 &&
+		       instrs[1].type == NAND_OP_ADDR_INSTR &&
+		       instrs[1].ctx.addr.naddrs == 2 &&
+		       instrs[1].ctx.addr.addrs[0] ==
+					(BERLIN2CD_ONFI_EXT_PARAM_COLUMN & 0xff) &&
+		       instrs[1].ctx.addr.addrs[1] ==
+					(BERLIN2CD_ONFI_EXT_PARAM_COLUMN >> 8) &&
+		       instrs[2].type == NAND_OP_CMD_INSTR &&
+		       instrs[2].ctx.cmd.opcode == NAND_CMD_RNDOUTSTART &&
+		       instrs[3].type == NAND_OP_DATA_IN_INSTR &&
+		       instrs[3].ctx.data.len ==
+					BERLIN2CD_ONFI_EXT_PARAM_LEN &&
+		       instrs[3].ctx.data.force_8bit;
 	default:
 		return false;
 	}
