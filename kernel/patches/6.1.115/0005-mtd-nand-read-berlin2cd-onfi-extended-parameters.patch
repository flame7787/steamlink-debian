@@ -1923,10 +2004,18 @@ static int marvell_nfc_monolithic_access_exec(struct nand_chip *chip,
 	onfi_params = nfc->caps->probe_only &&
 		      subop->instrs[0].type == NAND_OP_CMD_INSTR &&
