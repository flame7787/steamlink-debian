diff --git a/drivers/mtd/nand/raw/nand_base.c b/drivers/mtd/nand/raw/nand_base.c
index ea7e37a..c520996 100644
--- a/drivers/mtd/nand/raw/nand_base.c
+++ b/drivers/mtd/nand/raw/nand_base.c
@@ -5514,12 +5514,43 @@ static int nand_scan_ident(struct nand_chip *chip, unsigned int maxchips,
 	return 0;
 }
 
+/**
+ * nand_scan_ident_only - identify a NAND without attaching or scanning it
+ * @chip: NAND chip object
+ * @maxchips: number of chips to detect
+ *
+ * This is restricted to controller bring-up where page access is not safe yet.
+ * The caller must use nand_cleanup_ident_only() after a successful call.
+ */
+int nand_scan_ident_only(struct nand_chip *chip, unsigned int maxchips)
+{
+	if (!maxchips)
+		return -EINVAL;
+
+	return nand_scan_ident(chip, maxchips, NULL);
+}
+EXPORT_SYMBOL_GPL(nand_scan_ident_only);
+
 static void nand_scan_ident_cleanup(struct nand_chip *chip)
 {
 	kfree(chip->parameters.model);
 	kfree(chip->parameters.onfi);
 }
 
+/**
+ * nand_cleanup_ident_only - release resources allocated by identification
+ * @chip: NAND chip object
+ *
+ * This is the cleanup counterpart to nand_scan_ident_only().  It deliberately
+ * avoids the manufacturer and NAND-device cleanup performed by nand_cleanup(),
+ * because those objects are initialized only by the later scan phases.
+ */
+void nand_cleanup_ident_only(struct nand_chip *chip)
+{
+	nand_scan_ident_cleanup(chip);
+}
+EXPORT_SYMBOL_GPL(nand_cleanup_ident_only);
+
 int rawnand_sw_hamming_init(struct nand_chip *chip)
 {
 	struct nand_ecc_sw_hamming_conf *engine_conf;
